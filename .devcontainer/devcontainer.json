{
  "name": "The Ledger — SaaS Tracker",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt && python -c \"from app import init_db; init_db()\"",
  "forwardPorts": [5000],
  "portsAttributes": {
    "5000": {
      "label": "The Ledger Dashboard",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-python.pylint"]
    }
  }
}
